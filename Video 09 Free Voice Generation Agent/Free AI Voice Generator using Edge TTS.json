{
  "name": "Free AI Voice Generator using Edge TTS",
  "nodes": [
    {
      "parameters": {
        "content": "## 🎓 HOW THIS WORKFLOW WORKS\n1. Student types text in chat\n2. ⚙️ Settings node stores YOUR folder path + voice (edit ONCE here)\n3. Code node converts text into a real .txt file\n4. That file is saved to your computer\n5. Edge TTS (free, offline, no API key) reads the file and creates an MP3\n6. The MP3 is read back into n8n so you can preview / send it anywhere\n\n⚠️ PREREQUISITES:\n- Must run n8n SELF-HOSTED (Desktop app or Docker). n8n Cloud blocks 'Execute Command' + file system access for security.\n- Install Edge TTS on your machine: pip install edge-tts\n- Create the folder you set in the Settings node BEFORE running (e.g. mkdir on your PC)",
        "height": 512,
        "width": 380
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-160, -32],
      "id": "readme-node",
      "name": "📋 Read Me First"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.4,
      "position": [-128, 512],
      "id": "chat-trigger",
      "name": "When chat message received",
      "webhookId": "REPLACE_WITH_YOUR_WEBHOOK_ID"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "folderPath",
              "type": "string",
              "value": "/your/safe/folder/path"
            },
            {
              "id": "a2",
              "name": "voiceName",
              "type": "string",
              "value": "en-US-GuyNeural"
            },
            {
              "id": "a3",
              "name": "textInput",
              "type": "string",
              "value": "={{ $json.chatInput }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [144, 512],
      "id": "settings-node",
      "name": "⚙️ Settings (Edit Me First!)"
    },
    {
      "parameters": {
        "operation": "write",
        "fileName": "={{ $('⚙️ Settings (Edit Me First!)').item.json.folderPath }}/narration.txt",
        "options": { "append": false }
      },
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1.1,
      "position": [624, 512],
      "id": "save-file",
      "name": "💾 Save narration.txt"
    },
    {
      "parameters": {
        "command": "=edge-tts --file \"{{ $('⚙️ Settings (Edit Me First!)').item.json.folderPath }}/narration.txt\" --voice \"{{ $('⚙️ Settings (Edit Me First!)').item.json.voiceName }}\" --write-media \"{{ $('⚙️ Settings (Edit Me First!)').item.json.folderPath }}/narration.mp3\""
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [864, 512],
      "id": "generate-voice",
      "name": "🎙️ Generate Voice (Edge TTS)"
    },
    {
      "parameters": {
        "fileSelector": "={{ $('⚙️ Settings (Edit Me First!)').item.json.folderPath }}/narration.mp3",
        "options": {}
      },
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1.1,
      "position": [1104, 512],
      "id": "read-mp3",
      "name": "🔊 Read Final MP3"
    }
  ],
  "connections": {
    "When chat message received": {
      "main": [[{ "node": "⚙️ Settings (Edit Me First!)", "type": "main", "index": 0 }]]
    },
    "⚙️ Settings (Edit Me First!)": {
      "main": [[{ "node": "📝 Convert Text to File", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "binaryMode": "separate",
    "availableInMCP": false
  },
  "versionId": "REPLACE_WITH_YOUR_VERSION_ID",
  "meta": {
    "instanceId": "REPLACE_WITH_YOUR_INSTANCE_ID"
  },
  "id": "workflow-id",
  "tags": []
}
